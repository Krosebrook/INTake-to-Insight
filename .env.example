# ==============================================================
# INTake-to-Insight — Environment Variables
# ==============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# IMPORTANT: .env is gitignored. NEVER commit real API keys.
#
# For Vercel:       set these in Project Settings → Environment Variables
# For Cloudflare Pages: set these in Pages → Settings → Environment Variables
# ==============================================================

# Google Gemini API key (required)
# Obtain from: https://aistudio.google.com/app/apikey
# ⚠️  This key is embedded in the client-side JS bundle at build time.
#     Restrict it in the Google Cloud Console to your deployed domain(s).
GEMINI_API_KEY=your_gemini_api_key_here
